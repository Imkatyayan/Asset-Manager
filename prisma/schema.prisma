generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String      @id @default(cuid())
  name         String?
  email        String      @unique
  passwordHash String
  address      String?
  mobile       String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  portfolios   Portfolio[]
}

model Portfolio {
  id        String    @id @default(cuid())
  name      String
  source    String    @default("manual")
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  holdings  Holding[]
}

model Holding {
  id          String    @id @default(cuid())
  portfolioId String
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  symbol      String
  name        String
  quantity    Float
  avgPrice    Float
  currentPrice Float?
  sector      String?
  assetType   String    @default("equity")
  createdAt   DateTime  @default(now())
}
